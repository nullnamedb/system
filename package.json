{
  "name": "nullname-db",
  "version": "1.0.0",
  "description": "NullName DB - No brand. No name. No payment. The simplest database in the universe.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "production": "NODE_ENV=production node server.js",
    "install": "bash installment/install.sh",
    "uninstall": "bash installment/uninstall.sh",
    "config": "bash installment/config.sh",
    "status": "node server.js --status",
    "test": "node tests/run.js",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "clean": "node scripts/cleanup.js",
    "help": "node server.js --help"
  },
  "keywords": [
    "database",
    "json",
    "nosql",
    "simple",
    "free",
    "nullname",
    "zero-config",
    "file-based",
    "rest-api",
    "version-control",
    "backup",
    "authentication",
    "no-brand",
    "no-payment"
  ],
  "author": "NullName Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nullnamedb/system"
  },
  "bugs": {
    "url": "https://github.com/nullnamedb/system/issues"
  },
  "homepage": "https://github.com/nullnamedb/system",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "bcrypt": "^5.1.1",
    "uuid": "^9.0.1",
    "fs-extra": "^11.1.1",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "compression": "^1.7.4",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "optionalDependencies": {},
  "files": [
    "server.js",
    "queries.js",
    "auth.js",
    "user.js",
    "internet.js",
    "core/",
    "ui/",
    "docs/",
    "installment/",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "lib": "core",
    "doc": "docs",
    "example": "examples"
  }
}