# ============================================
# NULLNAME DB - ENVIRONMENT CONFIGURATION
# No brand. No name. No payment.
# Version: 1.0.0
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server port (default: 3000)
PORT=3455

# Server domain (used for file URLs and CORS)
DOMAIN=localhost

# Node environment (development / production)
NODE_ENV=production

# ============================================
# ADMIN USER CONFIGURATION
# ============================================

# Default admin username (change on first deploy!)
ADMIN_USER=admin

# Default admin password (change on first deploy! at least 4 characters)
ADMIN_PASS=nullname2025

# Root access key (for emergency access - generate random)
ROOT_KEY=7f3a8e2b9c1d4f6a8e2b9c1d4f6a8e2b

# ============================================
# SESSION CONFIGURATION
# ============================================

# Session timeout in milliseconds (default: 24 hours = 86400000)
SESSION_TIMEOUT=86400000

# Session cookie name
SESSION_COOKIE_NAME=nullname_session

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Allowed CORS origins (comma-separated, * for all)
ALLOWED_ORIGINS=*

# Admin IPs (comma-separated, bypass rate limiting)
ADMIN_IPS=127.0.0.1,::1

# Enable/disable SSL (true/false)
ENABLE_SSL=false

# SSL certificate path (if ENABLE_SSL=true)
SSL_CERT_PATH=

# SSL private key path (if ENABLE_SSL=true)
SSL_KEY_PATH=

# ============================================
# RATE LIMITING
# ============================================

# Rate limit window in milliseconds (default: 15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# Rate limit for uploads (per minute)
UPLOAD_RATE_LIMIT=30

# ============================================
# FILE CONFIGURATION
# ============================================

# Maximum file upload size in MB (default: 50)
MAX_FILE_SIZE_MB=50

# Allowed file types (comma-separated mime types)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/json

# Temporary file cleanup interval in milliseconds (default: 1 hour = 3600000)
TEMP_FILE_CLEANUP_MS=3600000

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Automatic backup interval in hours (default: 24, 0 = disabled)
BACKUP_INTERVAL_HOURS=24

# Maximum number of backups to keep (default: 10)
MAX_BACKUPS_KEEP=10

# Backup compression (true/false)
BACKUP_COMPRESSION=true

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level (debug / info / warn / error)
LOG_LEVEL=info

# Enable request logging (true/false)
ENABLE_REQUEST_LOG=true

# Enable query tracking (true/false)
ENABLE_QUERY_TRACKING=true

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Maximum storage in MB (default: 1024 = 1GB)
MAX_STORAGE_MB=1024

# Auto cleanup days for old data (default: 30, 0 = disabled)
AUTO_CLEANUP_DAYS=30

# Enable write-ahead logging (true/false)
ENABLE_WAL=true

# ============================================
# CACHE CONFIGURATION
# ============================================

# Cache TTL in milliseconds (default: 1 minute = 60000)
CACHE_TTL_MS=60000

# Maximum cache size in MB (default: 100)
MAX_CACHE_SIZE_MB=100

# ============================================
# FEATURE FLAGS
# ============================================

# Enable user signup (true/false)
ENABLE_SIGNUP=true

# Enable public read (true/false) - FALSE = everything needs auth
ENABLE_PUBLIC_READ=false

# Enable file uploads (true/false)
ENABLE_FILE_UPLOADS=true

# Enable version control (true/false)
ENABLE_VERSION_CONTROL=true

# Enable backup system (true/false)
ENABLE_BACKUP_SYSTEM=true

# ============================================
# PERFORMANCE TUNING
# ============================================

# Maximum concurrent downloads (default: 3)
MAX_CONCURRENT_DOWNLOADS=3

# Query timeout in milliseconds (default: 30 seconds = 30000)
QUERY_TIMEOUT_MS=30000

# Maximum query history per user (default: 1000)
MAX_QUERY_HISTORY=1000

# ============================================
# END OF CONFIGURATION
# ============================================